enum Use {
	once,
	daily,
	mo_fr,
	sa_su,
	weekly
};

Use stringToUse(const string& useStr) {
	if (useStr == "daily") return daily;
	else if (useStr == "Monday to Friday" || useStr == "mo_fr") return mo_fr;
	else if (useStr == "Saturday and Sunday" || useStr == "sa_su") return sa_su;
	else if (useStr == "weekly") return weekly;
	else if (useStr == "once") return once;
	return once;
}

int get_use_multiplier(Use use) {
	switch (use) {
	case once:
		return 1;  // Use once a week
	case daily:
		return 7;  // Use daily
	case mo_fr:
		return 5;  // Use from Monday to Friday
	case sa_su:
		return 2;  // Use on Saturdays and Sundays
	case weekly:
		return 1;  // Use weekly
	default:
		return 0;  // Handle unknown frequency as needed
	}
}


