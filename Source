class Household {
private:
	int persons;
	int squareMeters;
	bool isWaterHeated;
	float powerPrice;
	string powerSupplier;
	vector<Device*> devices; // Use pointers to devices

public:
	Household() : persons(0), squareMeters(0), isWaterHeated(false), powerPrice(0.0f), powerSupplier("") {}

	// Destructor
	~Household() {

		for (const auto& device : devices) {
			delete device;
		}

		// No need to delete consumers if they are not pointers
		cout << "Household (this: " << this << ") deleted" << endl;

	}


	// getters 
	int get_persons() const { return persons; }
	int get_squareMeters() const { return squareMeters; }
	bool get_isWaterHeated() const { return isWaterHeated; }
	float get_powerPrice() const { return powerPrice; }
	string get_powerSupplier() const { return powerSupplier; }
	const vector<Device*>& get_devices() const { return devices; }

	// Setters
	void set_persons(int p) { persons = p; }
	void set_squareMeters(int sqm) { squareMeters = sqm; }
	void set_isWaterHeated(bool isHeated) { isWaterHeated = isHeated; }
	void set_powerPrice(float price) { powerPrice = price; }
	void set_powerSupplier(const string& supplier) { powerSupplier = supplier; }

	// Member functions
	void add_device(Device* device) {
		devices.push_back(device);
	}

	void move_up(int position) {
		if (position > 1 && position <= devices.size()) {
			swap(devices[position - 1], devices[position - 2]);
		}
	}



	void copy_devices(Household* fromHousehold, Household* toHousehold) {
		for (const auto& device : fromHousehold->get_devices()) {

			Device* newdevice = device->get_a_copy();

			//// Add the new consumer to the target household
			toHousehold->add_device(newdevice);
		}
	}



	void input() {

		cout << "How many square metres does the household have? ";
		cin >> squareMeters;

		cout << "How many persons live in this household? ";
		cin >> persons;

		char hotWaterInput;
		cout << "Is hot water heated using electricity? (y(es) or n(o)) ";
		cin >> hotWaterInput;
		isWaterHeated = (hotWaterInput == 'y' || hotWaterInput == 'Y');

		cout << "Power price for this household in EUR? ";
		cin >> powerPrice;

		cout << "Power supplier for this household? ";
		cin.ignore();  // To clear the newline character from the buffer
		getline(cin, powerSupplier);

	}


	float calculateTotalConsumption() const {
		float total = 0.0f;
		for (const auto& device : devices) {
			total += device->annual_kWh();
		}
		return total;
	}



	// Member function for printing
	void printhousehold() const {
		cout << setw(COLUMN_WIDTH) << left << "(this: " << this << ")" << endl;
		cout << setw(COLUMN_WIDTH) << left << "Price for one kWh: " << fixed << setprecision(2) << powerPrice * 100 << " ct/kWh" << endl;
		cout << setw(COLUMN_WIDTH) << left << "Power Supplier: " << powerSupplier << endl;
		cout << setw(COLUMN_WIDTH) << left << "Square Meters: " << squareMeters << " sqm" << endl;
		cout << setw(COLUMN_WIDTH) << left << "Persons: " << persons << endl;
		cout << setw(COLUMN_WIDTH) << left << "Water Heated Electrically: " << (isWaterHeated ? "Yes" : "No") << endl;
		cout << setw(COLUMN_WIDTH) << left << "List of Consumers:" << endl;
		cout << "----------------------------------------------------------------------\n";

		// Iterate through consumers and print their details
		for (size_t i = 0; i < devices.size(); ++i) {
			cout << setw(4) << right << (i + 1) << ": ";
			devices[i]->print(0, powerPrice);
		}

		// Calculating total power consumption and costs
		float totalAnnualConsumption = calculateTotalConsumption();
		float powerConsumptionSquareMeters = squareMeters * ANNUAL_CONSUMPTION_SQM;
		float powerConsumptionAllPersons = persons * (isWaterHeated ? ELECTRIC_WATERHEATED : ANNUAL_CONSUMPTION_PERSON);
		float totalPowerConsumption = totalAnnualConsumption + powerConsumptionSquareMeters + powerConsumptionAllPersons;
		float totalCosts = totalPowerConsumption * powerPrice;

		cout << setw(COLUMN_WIDTH) << left << "Power Consumption Square Meters: " << powerConsumptionSquareMeters << " kWh" << endl;
		cout << setw(COLUMN_WIDTH) << left << "Power Consumption All Persons: " << powerConsumptionAllPersons << " kWh" << endl;
		cout << setw(COLUMN_WIDTH) << left << "Total Annual Power Consumption: " << totalPowerConsumption << " kWh" << endl;
		cout << setw(COLUMN_WIDTH) << left << "Total Annual Power Costs: " << totalCosts << " EUR" << endl;

		cout << "===================================================================================================================" << endl;
	}
};

