class Immobile : public Consumer {
private:
	float watt_standby;
	float hours;

public:

	//constructor 
	Immobile(Device* device = nullptr) :Consumer(device) {
	}

	// Destructor
	virtual ~Immobile() {
		cout << "Immobile: " << get_description() << "  (this: " << this << ") deleted" << endl;
	}

	float get_watt_standby() const { return watt_standby; }
	float get_hours() const { return hours; }
	void set_watt_standby(float ws) { watt_standby = ws; }
	void set_hours(float h) { hours = h; }

	// Member functions for calculations
	virtual float annual_hours_of_use() const {
		switch (this->get_use()) {
		case daily: return hours * 365;
		case mo_fr: return hours * 5 * 52;
		case sa_su: return hours * 2 * 52;
		case weekly: return hours * 52;
		default: return hours;
		}
	}

	virtual float annual_hours_of_standby() const {
		return 8760 - annual_hours_of_use();
	}

	// Implementation of the pure virtual function
	virtual float annual_kWh() const override
	{

		float activeHours = annual_hours_of_use();
		float standbyHours = annual_hours_of_standby();

		return (this->get_watt() * activeHours + watt_standby * standbyHours) / 1000;
	}

	// Member function for input
	virtual void input() override {
		Consumer::input();

		cout << "How many watts standby will it have? ";
		cin >> watt_standby;

		cout << "How many hours will it be operating then? ";
		cin >> hours;

	}

	virtual void print(int intValue, float powerPrice) const override {
		Device::print(intValue, powerPrice);
		cout << "                              (this: " << this << ")" << endl;
		cout << setw(COLUMN_WIDTH) << "Power consumption (W): " << this->get_watt() << endl;
		cout << setw(COLUMN_WIDTH) << "Standby consumption (W): " << watt_standby << endl;
		cout << setw(COLUMN_WIDTH) << "Usage: " << useToString(this->get_use()) << endl;
		cout << setw(COLUMN_WIDTH) << "Annual hours of use: " << annual_hours_of_use() << endl;
		cout << setw(COLUMN_WIDTH) << "Annual hours of standby: " << annual_hours_of_standby() << endl;
		cout << setw(COLUMN_WIDTH) << "Annual consumption (kWh): " << annual_kWh() << endl;
		cout << setw(COLUMN_WIDTH) << "Annual costs (EUR): " << annual_kWh() * powerPrice << endl; // Assuming get_powerPrice() is accessible 

		cout << "****************************************************************************************************************" << endl;

	}


	// Implementierung der virtuellen Funktion in der Klasse Immobile
	virtual Device* get_a_copy() const override {

		Immobile* copy = new Immobile;
		*copy = *this;
		return copy;

	}


	virtual string get_string_for_file(char separator) const override {
		//Consumer::get_string_for_file(separator);
		std::stringstream ss;
		ss << "Immobile" << separator << this->get_description() << separator << this->get_hours() << separator << this->get_use()
			<< separator << this->get_watt() << separator << this->get_watt_standby(); // Add other attributes as needed

		return ss.str();
	}


};

