class Consumer : public Device {
private:
	float watt;
	Use use;
	static int objectCount; // Static variable to count the number of objects created

public:

	// Default constructor
	Consumer(Device* device = nullptr) : Device(device), watt(0.0f), use(once) {

		++objectCount;
		this->set_description("");
	}


	// Destructor
	virtual ~Consumer() {
		objectCount;
		cout << "consmer: " << get_description() << "  (this: " << this << ") deleted" << endl;
	}

	// Static getter function
	static int getobjectcount() { return objectCount; }

	// Getters
	float get_watt() const { return watt; }
	Use get_use() const { return use; }

	// Setters
	void set_watt(float w) { watt = w; }
	void set_use(Use u) { use = u; }


	// Implementation of the pure virtual function
	virtual float annual_kWh() const override = 0;


	
	virtual Device* get_a_copy() const override = 0;

	// Pure virtual function for get_string_for_file with one character as a parameter
	virtual string get_string_for_file(char character)  const override = 0;

	virtual void print(int intValue, float floatValue) const override = 0;

	// Member function for input
	void input() override {

		Device::input();

		cout << "How many watts will it have? ";
		cin >> watt;


		// Consume the remaining newline character
		cin.ignore(numeric_limits<streamsize>::max(), '\n');

		string useChoice;
		cout << "How often will it be used?\n"
			<< "daily  (d)\n"
			<< "mo_fr  (m)\n"
			<< "once   (o)\n"
			<< "sa_su  (s)\n"
			<< "weekly (w)? ";
		cin >> useChoice;

		// Convert the input string to the Use enum value
		if (useChoice == "d") use = daily;
		else if (useChoice == "m") use = mo_fr;
		else if (useChoice == "o") use = once;
		else if (useChoice == "s") use = sa_su;
		else if (useChoice == "w") use = weekly;
		else use = once; // Default to 'once' if the input doesn't match



		// Consume the remaining newline character to prepare for the next input
		cin.ignore(numeric_limits<streamsize>::max(), '\n');
	}

	// Helper function to convert the Use enum to a string
	string useToString(Use use) const {
		switch (use) {
		case daily: return "daily";
		case mo_fr: return "Monday to Friday";
		case sa_su: return "Saturday and Sunday";
		case weekly: return "weekly";
		case once: return "once";
		default: return "unknown";
		}
	}


};

