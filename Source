class House {
private:
	int number_of_households;
	vector<Household*> households;  // Vector of raw pointers to Household objects
	Address address;

public:



	int get_number_of_households() const {
		return number_of_households;
	}

	void increment_number_of_households() {
		++number_of_households;
	}

	// Constructor
	House(int num_households, const Address& addr)
		: number_of_households(num_households), address(addr) {
		households.resize(number_of_households, nullptr);
	}

	House() {}

	// Destructor
	~House() {
		for (auto& household : households) {
			delete household;
		}
		cout << "House (this: " << this << ") deleted" << endl;
	}

	// Method to get a household
	Household* get_household(int n) const {
		if (n >= 0 && n < number_of_households) {
			return households[n];
		}
		else {
			return nullptr;
		}
	}

	// Method to set a household
	void set_household(Household* household, int indexofhouses) {
		if (indexofhouses >= 0 && indexofhouses < number_of_households) {
			delete households[indexofhouses];  // Free existing household
			households[indexofhouses] = household;
		}
	}



	void set_address(const Address& new_address) {
		address = new_address;
	}

	void set_number_of_households(int new_number) {
		number_of_households = new_number;
		households.resize(number_of_households); // Resize the vector to the new size
	}

	// Method to print all households
	void print_all() const {
		if (this == nullptr) {
			cout << "House is a nullptr, please first choose 'h' to initialise a new house.\n";
			return;
		}

		cout << "======================================================================\n"
			<< "                                HOUSE\n"
			<< "======================================================================\n"
			<< "                              (this: " << this << ")\n"
			<< "                            address: " << address.to_string() << "\n"
			<< "               number of households: " << number_of_households << "\n"
			<< "Total number of power consumers in all households: " << Consumer::getobjectcount() << "\n"
			<< "======================================================================\n";

		for (int i = 0; i < households.size(); ++i) {
			if (households[i]) { // Check if the pointer is not nullptr
				cout << "H O U S E H O L D   N O   " << (i + 1) << "   P O W E R   C O N S U M P T I O N\n"
					<< "----------------------------------------------------------------------\n";
				households[i]->printhousehold();
			}

		}

		cout << "======================================================================\n";
	}


	vector<Household*>& getHouseholds() {
		return households;
	}


	void clear_households() {
		for (auto& household : households) {
			delete household;
		}
		households.clear();
	}


	void read_from_file(const string& filename, char separator, House& house) const {
		ifstream file(filename);
		if (!file.is_open()) {
			cerr << "Unable to open file: " << filename << endl;
			return;
		}

		// Read and handle the first line for house information
		string houseInfo;
		getline(file, houseInfo);
		stringstream houseStream(houseInfo);


		houseStream.ignore(numeric_limits<streamsize>::max(), separator); // Skip the initial part (e.g., "A5;")

		int numHouseholds;

		houseStream >> numHouseholds;

		houseStream.ignore(numeric_limits<streamsize>::max(), separator); // Ignore the separator after the number of households

		string street, houseNumber, zip, city;
		getline(houseStream, street, separator);
		getline(houseStream, houseNumber, separator);
		getline(houseStream, zip, separator);
		getline(houseStream, city, separator);



		house.address.set_street(street);
		house.address.set_no(houseNumber);
		house.address.set_zip(zip);
		house.address.set_city(city);
		house.number_of_households = numHouseholds;


		// Update the house's address and number of households
		house.clear_households();
		house.households.resize(house.number_of_households, nullptr);


		string line;
		int currentHouseholdIndex = -1;
		Household* currentHousehold = nullptr;

		while (getline(file, line)) {
			stringstream lineStream(line);
			string token;
			getline(lineStream, token, separator);

			if (token == "Household") {
				if (currentHousehold != nullptr) {
					// Save the previous household before creating a new one
					house.set_household(currentHousehold, currentHouseholdIndex);
				}

				currentHousehold = new Household();
				lineStream >> currentHouseholdIndex;
				lineStream.ignore(numeric_limits<streamsize>::max(), separator);
				currentHouseholdIndex--; // Adjust for zero-based indexing

				bool isWaterHeated;
				int persons, squareMeters;
				float powerPrice;
				string powerSupplier;

				lineStream >> boolalpha >> isWaterHeated;
				lineStream.ignore(numeric_limits<streamsize>::max(), separator);
				lineStream >> persons;
				lineStream.ignore(numeric_limits<streamsize>::max(), separator);
