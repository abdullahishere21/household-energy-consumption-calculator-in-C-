	void write_to_file(const string& filename, char separator) const {
		ofstream file(filename);
		if (!file.is_open()) {
			cerr << "Error opening file for writing: " << filename << endl;
			return;
		}

		// Write header with the format "A5;number_of_households;address"
		file << "A6" << separator << number_of_households << separator;
		file << address.get_street() << separator << address.get_no() << separator;
		file << address.get_zip() << separator << address.get_city() << '\n';

		// Write details of each initialized household
		for (int i = 0; i < households.size(); i++) {
			const Household* household = households[i];
			if (household && household->get_persons() > 0) {
				// Write household details
				file << "Household" << separator << (i + 1) << separator
					<< (household->get_isWaterHeated() ? "true" : "false") << separator
					<< household->get_persons() << separator << household->get_squareMeters() << separator
					<< household->get_powerPrice() << separator << household->get_powerSupplier() << "\n";

				// Write consumer details for each consumer in the household
				const auto& devices = household->get_devices();
				for (const auto& device : devices) {
					file << device->get_string_for_file(separator) << "\n";
				}
			}
		}

		file.close();
	}




