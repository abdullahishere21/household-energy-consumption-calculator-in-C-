	string get_description() const { return description; }

	void set_description(const string& desc) { description = desc; }


	Device* getNext() {
		return this->next;
	}

	void set_next(Device* nextDevice) {
		this->next = nextDevice;
	}

	Device(Device* nextDevice = nullptr) {

		this->next = nextDevice;
	}

	virtual ~Device() {
		cout << "Device: " << this->description << " (this:" << this << ") deleted" << endl;
	}

	// Public virtual member function for input
